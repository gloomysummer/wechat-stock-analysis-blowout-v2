# ============================================
# 爆款公众号文章 Skill - 环境变量配置
# ============================================
# 复制本文件为 .env，然后填入你的真实 Token
# cp .env.example .env

# MiniMax LLM（用于 AI 写文章）
# 获取方式：https://www.minimaxi.com → 注册 → API Keys
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com

# Tushare 财报数据（用于获取上市公司财务数据）
# 获取方式：https://tushare.pro → 注册 → 个人主页 → Token
TUSHARE_TOKEN=

# ModelScope AI 配图（用于生成文章配图）
# 获取方式：https://modelscope.cn → 注册 → 右上角头像 → API Token
MODELSCOPE_TOKEN=

# 微信公众号（用于推送文章到草稿箱，可选）
# 获取方式：mp.weixin.qq.com → 开发 → 基本配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 发布服务器（可选，不填则跳过在线发布）
PUBLISH_SERVER_IP=
PUBLISH_SERVER_PORT=80
